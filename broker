<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BrokerFlow — Real Estate Pro</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #05080f; /* Your preferred background */
            --surface: #0b0f1a;
            --border: #1e293b;
            --accent: #6366f1;
            --text: #f1f5f9;
            --muted: #64748b;
            --green: #00FFBB;
            --gold: #f59e0b;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 20px;
        }

        /* Listing Cards */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            transition: transform 0.2s;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
        }

        .card-img {
            height: 180px;
            background: #1a2235;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
        }

        .card-content { padding: 20px; }

        .price {
            font-size: 22px;
            font-weight: 800;
            color: var(--green);
            margin-bottom: 4px;
        }

        .address {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .tag {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            background: rgba(99, 102, 241, 0.1);
            color: var(--accent);
        }

        /* Stats Bar */
        .stats {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .stat-box {
            flex: 1;
            background: var(--surface);
            padding: 20px;
            border-radius: 14px;
            border: 1px solid var(--border);
        }

        .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; }
        .stat-val { font-size: 24px; font-weight: 800; }

        input {
            width: 100%;
            padding: 12px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: white;
            margin-bottom: 10px;
        }

        button {
            background: var(--accent);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <header>
        <h1 style="font-size: 28px; font-weight: 800;">Broker<span>Flow</span></h1>
        <p style="color: var(--muted); margin-top: -10px;">Real Estate Management Portfolio</p>
    </header>

    <div class="stats">
        <div class="stat-box">
            <div class="stat-label">Active Listings</div>
            <div class="stat-val" id="count-listings">0</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Projected Commission</div>
            <div class="stat-val" style="color: var(--gold);">$0</div>
        </div>
    </div>

    <div style="background: var(--surface); padding: 25px; border-radius: 16px; border: 1px solid var(--border);">
        <h3 style="margin-top:0">Add New Property</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <input type="text" id="prop-address" placeholder="Property Address (e.g. Eretria, Greece)">
            <input type="number" id="prop-price" placeholder="Price ($)">
            <select id="prop-type" style="background: var(--surface); color: white; border: 1px solid var(--border); border-radius: 8px; padding: 10px;">
                <option value="Sale">For Sale</option>
                <option value="Rental">Rental / Airbnb</option>
            </select>
            <button onclick="addProperty()">List Property</button>
        </div>
    </div>

    <div class="grid" id="property-grid">
        </div>

    <script>
        let properties = JSON.parse(localStorage.getItem('broker_properties')) || [];

        function addProperty() {
            const addr = document.getElementById('prop-address').value;
            const price = document.getElementById('prop-price').value;
            const type = document.getElementById('prop-type').value;

            if(!addr || !price) return alert("Fill in details");

            const newProp = {
                id: Date.now(),
                address: addr,
                price: price,
                type: type
            };

            properties.unshift(newProp);
            saveAndRender();
            
            document.getElementById('prop-address').value = '';
            document.getElementById('prop-price').value = '';
        }

        function saveAndRender() {
            localStorage.setItem('broker_properties', JSON.stringify(properties));
            render();
        }

        function render() {
            const grid = document.getElementById('property-grid');
            document.getElementById('count-listings').innerText = properties.length;
            
            grid.innerHTML = properties.map(p => `
                <div class="card">
                    <div class="card-img">Property Photo</div>
                    <div class="card-content">
                        <div class="tag">${p.type}</div>
                        <div class="price">$${Number(p.price).toLocaleString()}</div>
                        <div class="address">${p.address}</div>
                        <button onclick="deleteProp(${p.id})" style="background: #ff3b5c; padding: 5px 10px; font-size: 11px;">Remove</button>
                    </div>
                </div>
            `).join('');
        }

        function deleteProp(id) {
            properties = properties.filter(p => p.id !== id);
            saveAndRender();
        }

        render();
    </script>
</body>
</html>
